# MCP Server Configuration
MCP_COPILOT_SERVER_TOKEN=your-secure-token-here

# API Tokens
AZION_TOKEN=your-azion-api-token
EDGE_AI_TOKEN=your-edge-ai-token
OPENAI_API_KEY=your-openai-api-key

# Edge AI Configuration
EDGE_AI_URL=your-edge-ai-endpoint-url

# Origin Configuration (internal origin endpoints to avoid CDN loop)
API_ORIGIN_URL=your-api-origin-base-url
SSO_ORIGIN_URL=your-sso-origin-url

# Environment
NODE_ENV=production